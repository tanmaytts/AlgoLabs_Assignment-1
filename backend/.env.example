# Port the Express server listens on
PORT=4000

# Supabase project URL (find it in Project Settings > API)
SUPABASE_URL=

# Supabase service-role secret key (never expose this on the client side)
SUPABASE_SERVICE_KEY=

# Path to the Python interpreter that has yfinance installed.
# Locally use the venv:  PYTHON_BIN=./.venv/bin/python
# In Docker the system python3 has all deps installed:  PYTHON_BIN=python3
PYTHON_BIN=python3

# Origin allowed by CORS - set to your frontend dev server.
# Leave blank to allow all origins (useful in development).
CORS_ORIGIN=http://localhost:5173
